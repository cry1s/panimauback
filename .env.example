# .env.example
# Copy this file to .env and fill real values.

# Bot token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram group ID where the bot watches messages
GROUP_ID=-1234567890

# Target channel username or ID
CHANNEL_ID=@your_channel

# Comma-separated Telegram user IDs allowed to run admin commands
ADMIN_IDS=123456789,987654321

# Optional: delay before publishing media, in seconds
DOWNLOAD_DELAY_SECONDS=5
